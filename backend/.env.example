# ProfBetGeng — environment variables
# Copy to backend/.env and fill in real values (never commit .env)

# Runtime
ENVIRONMENT=development
AUTH_ENABLED=true
BATCH_ENABLED=false

# Admin
ADMIN_TOKEN=change-me-before-production

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# CORS (comma-separated list of allowed frontend origins)
# Default covers local Vite dev servers. In production set to your Vercel URL.
# ALLOWED_ORIGINS=https://your-app.vercel.app
